    {
      "id": "ZGJ52_yhHY9V3asj6s2dP",
      "type": "text",
      "x": -117.90199367213904,
      "y": -6387.987067680811,
      "width": 1655.6763916015625,
      "height": 237.37422094497015,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "0YrjSpDCksS6Y7Z2t9Aun",
      "index": "bAr",
      "roundness": null,
      "seed": 861850148,
      "version": 1249,
      "versionNonce": 1590815012,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769264414332,
      "link": null,
      "locked": false,
      "text": "In git, you can track each change in your code and who changed it. Each change is commented, in a way which is \neasy to track down. \nIn git, you have versions of the project, not just versions of each file. A project involves many scripts, \nwhich are interdependent. In git, you can always go back to a previous working version.\nIn git, you can experiment on your own without breaking the main code (\"branching\")\n \n",
      "fontSize": 27.128482393710875,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In git, you can track each change in your code and who changed it. Each change is commented, in a way which is \neasy to track down. \nIn git, you have versions of the project, not just versions of each file. A project involves many scripts, \nwhich are interdependent. In git, you can always go back to a previous working version.\nIn git, you can experiment on your own without breaking the main code (\"branching\")\n \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
